{
  "name": "Image Share Target",
  "short_name": "ShareTarget",
  "start_url": "/REPLACE_WITH_YOUR_REPO_NAME/",
  "scope": "/REPLACE_WITH_YOUR_REPO_NAME/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#007bff",
  "icons": [
    {
      "src": "https://via.placeholder.com/192",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "https://via.placeholder.com/512",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "share_target": {
    "action": "/REPLACE_WITH_YOUR_REPO_NAME/",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "image",
          "accept": ["image/*"]
        }
      ]
    }
  }
}
